# ========================================
# Database configuration (PostgreSQL + pgvector)
# ========================================
# Internal/private URL used first by the API (recommended for same network providers).
# Same URL is used for SQLAlchemy (RAG tables) and for LangGraph Postgres checkpoints
# (tables created on startup via langgraph-checkpoint-postgres setup()).
DATABASE_URL=postgresql://<user>:<password>@<internal-host>:<port>/<database_name>

# Public URL fallback used only when DATABASE_URL is missing or unreachable
DATABASE_PUBLIC_URL=postgresql://<user>:<password>@<public-host>:<port>/<database_name>

# ========================================
# OpenAI configuration
# ========================================
# API key used by the official OpenAI Python client
OPENAI_API_KEY=sk-<your-openai-api-key>
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Chat model for the LangGraph agent (POST /chat)
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional: extra system instructions for the LangGraph ReAct loop (final answer uses structured JSON: reply + source_document_ids).
# AGENT_SYSTEM_PROMPT=You are a helpful assistant...

# CORS origins accepted by FastAPI (comma-separated). Use * only in development.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173

# ========================================
# Firebase / Google Cloud Storage (optional)
# Only required if you want to store files in Firebase
# ========================================
FIREBASE_PROJECT_ID=<your-firebase-project-id>
FIREBASE_PRIVATE_KEY_ID=<your-firebase-private-key-id>
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<your-private-key>\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=<your-firebase-client-email>
FIREBASE_CLIENT_ID=<your-firebase-client-id>
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/<your-client-email-encoded>
FIREBASE_STORAGE_BUCKET=<your-project-id>.firebasestorage.app

# ========================================
# Application server
# ========================================
# HOST should usually be 0.0.0.0 in production (e.g. Railway)
HOST=0.0.0.0
PORT=8000

